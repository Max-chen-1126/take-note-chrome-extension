WXT_BACKEND_URL=http://localhost:8080
# Local-E2E auth shortcut: when set, getIdToken() returns this value directly
# instead of running the launchWebAuthFlow/Google OAuth flow. Leave unset to
# exercise the real interactive auth flow.
WXT_DEV_BEARER=
# Google OAuth2 Web client ID used as `aud` for the id_token (Phase B backend
# alignment required before this path is used outside of WXT_DEV_BEARER).
WXT_OAUTH_CLIENT_ID=
